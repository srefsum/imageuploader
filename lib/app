sub complete {
    my ( $request, $httpreq ) = @_;
    my %resp = %{ preInit( $request, $httpreq ) };

    $resp{Documentation}{post}{summary}     = 'A generic lookup of count into a given table based on a single key in one column';
    $resp{Documentation}{post}{description} = 'Optional extended description in CommonMark or HTML';
    $resp{Documentation}{post}{operationId} = NextId('Self Service');
    $resp{Documentation}{post}{tags}        = ['Self Service'];
    AddResponseDoc(\%resp,'POST','200 404 500');   

    my $line = $resp{Line};
    $line = getSingleValueParams( $line, \%param_uid,     \%resp, 'usrname',    ['POST'], true );
    $line = getSingleValueParams( $line, \%param_psw,     \%resp, 'uuid',       ['POST'], true );
    $line = getSingleValueParams( $line, \%param_psw,     \%resp, 'otp',        ['POST'], true );
    
    if ($ENV{'REQUEST_METHOD'} eq 'POST' ) {
        $resp{Params}{ postdata }        = $httpreq->param('POSTDATA');
        $resp{Params}{ postdata_length } = $ENV{'CONTENT_LENGTH'};
        $resp{Params}{ postdata_type   } = $ENV{'CONTENT_TYPE'};
        $resp{Params}{ uid  } = $httpreq->param('usrname');
        $resp{Params}{ uuid } = $httpreq->param('uuid');
        $resp{Params}{ otp  } = $httpreq->param('otp');
    } 
    
    CommonApiHandler::getHeaderValueParams( \%CommonApiHandler::param_request_id, \%resp, 'X-Request-ID', ['POST'] );
    CommonApiHandler::getHeaderValueParams( \%CommonApiHandler::param_trace_id,   \%resp, 'X-TRACE-ID',   ['POST'] );
    CommonApiHandler::getHeaderValueParams( \%CommonApiHandler::param_accept,     \%resp, 'HTTP-ACCEPT',  ['POST'] );

    allParametersUsed( $line, \%resp );

    if ( !defined( $resp{api} ) ) {
		if ( $ENV{'REQUEST_METHOD'} eq 'POST' ) {
            my ($result,$record) = SessionFile::GetRecord($resp{Params}{ uuid });
			if ($result == 1 and defined($record) ) {
                
				$resp{record_result}             = $result;
				$resp{record}{otp_compare}       = (StringCrypt::mydecrypt($record->{sessionid}, $record->{otp_token}) eq $resp{Params}{ otp  }) ? "OK": "Fail";
                # Only if changed by user
                if ($record->{resetuser} ne 'admin')  {
                    $resp{record}{ldap_athenticated} = Authenticate::ldapAuthenticate(\%resp, $record->{uid}, StringCrypt::mydecrypt($record->{sessionid}, $record->{oldpasswd}));
                } else {
                    $resp{record}{ldap_athenticated} = 1;
                }
                
                if ($record->{level} eq 'GROUPADMINPW') {
				$resp{record}{ad_athenticated}   = ADConnection::Authenticate    ($record->{uid}, StringCrypt::mydecrypt($record->{sessionid}, $record->{newpasswd}));
                } else {
                    $resp{record}{ad_athenticated}   = 0;
                }
								
				# Check that all is OK
				my $printPage = undef;
				if (( $resp{record}{otp_compare}       eq "OK") and        # Correct token
					( $resp{record}{ldap_athenticated} eq "1")  and        # Correct old password 
					( $resp{record}{ad_athenticated}   eq "0")) {          # Failed as expected
				#    prepare the magic    
					( $resp{status}, $resp{results}{txt}, $printPage ) = Pages::pages( "completed" );
				} else {
					( $resp{status}, $resp{results}{txt}, $printPage ) = Pages::pages( "failed" );
				}
                
                ### Set password
                ### 
				
				SessionFile::DeleteRecord($resp{Params}{ uuid });
				return (finelizeRequest(\%resp, $printPage,'text/html')) if (defined($printPage));
			} else {
                logtosys('err',     "GetRecord failed with uuid: " . $resp{Params}{ uuid });
                my $printPage = undef;
                ( $resp{status}, $resp{results}{txt}, $printPage ) = Pages::pages( 'head' );
                return(finelizeRequest(\%resp, $printPage,'text/html')) if (defined($printPage));
            }
		}
    }
    
    return(finelizeRequest(\%resp)); 
}

