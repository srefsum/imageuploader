sub appdoc {
    my $api = shift;

    $api->{oas}{info}{title}       = $SystemName;
    $api->{oas}{info}{description} = $SystemDescription;
    $api->{oas}{info}{version}     = $version_string{version};

    if ($config->{AUTHENTICATE} eq 'ON') {
        $api->{oas}{components}{securitySchemes}{BasicAuth}{type}          = "http";
        $api->{oas}{components}{securitySchemes}{BasicAuth}{scheme}        = "basic";
        $api->{oas}{components}{securitySchemes}{BearerAuth}{type}         = "http";
        $api->{oas}{components}{securitySchemes}{BearerAuth}{scheme}       = "bearer";
        $api->{oas}{components}{securitySchemes}{BearerAuth}{bearerFormat} = "JWT";

        #Global Authentication needed
        $api->{oas}{security} = [{BasicAuth => []},{BearerAuth => []}];
    }

    # Tags to group API
    my $t = 0;
    if (defined($api->{oas}{tags})) {
         $t = scalar @{$api->{oas}{tags}};
    }
    $api->{oas}{tags}[ $t   ]{name}        = 'Self Service';
    $api->{oas}{tags}[ $t++ ]{description} = "Self Service creates an API and an application that can modify the openLDAP ";


    push @{ $api->{oas}{servers} }, {
        url         => 'http://selfservice.test.as2116.net/cgi-bin/app',
        description => 'Optional server description, e.g. Internal staging server for testing'
      };
    push @{ $api->{oas}{servers} }, {
        url         => 'http://selfservice.dev.as2116.net/cgi-bin/app',
        description => 'Optional server description, e.g. Main (production) server'
      };
    return;  
}

sub landing_pages {
    
    my ( $request, $httpreq ) = @_;
    my %resp = %{ preInit( $request, $httpreq ) };
    
    
    my $line = $resp{Line};

    $line = getSingleValueParams( $line, \%param_pages,   \%resp, 'page',  ['GET'], false );
    $line = getSingleValueParams( $line, \%param_uid,     \%resp, 'uid',   ['GET'], false );
    CommonApiHandler::getHeaderValueParams( \%CommonApiHandler::param_request_id, \%resp, 'X-Request-ID', ['GET'] );
    CommonApiHandler::getHeaderValueParams( \%CommonApiHandler::param_trace_id,   \%resp, 'X-TRACE-ID',   ['GET'] );
    CommonApiHandler::getHeaderValueParams( \%CommonApiHandler::param_accept,     \%resp, 'HTTP-ACCEPT',  ['GET'] );
    allParametersUsed( $line, \%resp );
    $resp{Params}{ page } = 'head';

    if ( !defined( $resp{api} ) ) {
		if ( $ENV{'REQUEST_METHOD'} eq 'GET' ) {
			$resp{Params}{page} = uri_unescape($resp{Params}{page}); 
			my $printPage = undef;
			( $resp{status}, $resp{results}{txt}, $printPage ) = Pages::pages( $resp{Params}{ page } );
			return(finelizeRequest(\%resp, $printPage,'text/html')) if (defined($printPage));
		}
    }
    
    return(finelizeRequest(\%resp)); 
}

