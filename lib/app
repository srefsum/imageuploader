sub getAccessLevel {
	my $ldap = shift;

	if (!defined($ldap->{Authorizations})) {return 'GROUPUSERPW';}

	my %levels = ();
	for (my $i = 0;$i < scalar @{$ldap->{Authorizations}{oss_ldap}{auth}};$i++) {
		for my $levelgroup (keys %{$config->{PASSWORDLEVEL}}) {
			for (my $s = 0;$s < scalar @{$config->{PASSWORDLEVEL}{$levelgroup}};$s++) {
				if ($config->{PASSWORDLEVEL}{$levelgroup}[$s] eq $ldap->{Authorizations}{oss_ldap}{auth}[$i]) {
					$levels{$levelgroup}++;
				}  else {
					$levels{othergroup}++;
				}  
			}
		}		
	}		
	for (my $i = 0;$i < scalar @{$ldap->{Authorizations}{oss_ldap}{roles}};$i++) {
		for my $levelgroup (keys %{$config->{PASSWORDLEVEL}}) {
			for (my $s = 0;$s < scalar @{$config->{PASSWORDLEVEL}{$levelgroup}};$s++) {
				if ($config->{PASSWORDLEVEL}{$levelgroup}[$s] eq $ldap->{Authorizations}{oss_ldap}{roles}[$i]) {
					$levels{$levelgroup}++;
				}  else {
					$levels{othergroup}++;
				}
			}
		}
	}
	
	if    ($levels{GROUPAPIPW} > 0 and !defined($levels{othergroup})) { return 'GROUPAPIPW';} # API USERS
	elsif ($levels{GROUPADMINPW} > 0) {return 'GROUPADMINPW';}                                # ADMIN LEVEL  
	elsif ($levels{GROUPSUPERPW} > 0) {return 'GROUPSUPERPW';}                                # SUPER USERS
	else  {return 'GROUPUSERPW';}                                                             # NORMAL USERS
}

sub GlobalConfig {

    my %conf;
    my $confobj;
    my $filename = 'config.txt';
    my $confpath = $FindBin::Bin . "/../config";

    my $realconf     = $confpath . '/' . $filename;
    my $testconfpath = '../config';
    my $testconf     = $testconfpath . '/' . $filename;

    if ( -e $testconf ) {
        $confobj = new Config::General($testconf);

        #print "$ApplicationName startet med test konfigurering fra fil: " . $testconf . "\n";
    } else {
        unless ( -e $realconf ) {
            print "\n"
              . "  Konfigurasjonsfilen $realconf finnes ikke. \n"
              . "  Kopier fra $ApplicationPath../configuration/application-config.conf \n"
              . "  til $realconf\n"
              . "  Rediger og tilpass etter kopiering." . "\n\n";
            die;
        }
        $confobj = new Config::General($realconf);
    }

    %conf   = $confobj->getall;
    $config = \%conf;
    

    if ( !defined( $config->{AUTHENTICATE}) )  {
        $config->{AUTHENTICATE} = 'ON'; 
    }
    
    @{$config->{METHODS}} = qw ( GET POST  PUT PATCH  DELETE );
    if ( defined( $config->{LOGLEVELFILE} )) {
        $config->{LOGLEVELFILE} = $FindBin::Bin . '/' . $config->{LOGLEVELFILE};
    }
    if ( defined( $config->{LOGFILENAME} )) {
        $config->{LOGFILENAME} = $FindBin::Bin . '/' . $config->{LOGFILENAME};
    }
    
    $config->{SystemName} = $SystemName;
    
    if ( defined( $config->{LOGLEVELFILE} ) and ( -s $config->{LOGLEVELFILE} ) ) {
        open( my $FH, '<', $config->{LOGLEVELFILE} ) or die $!;
        while (<$FH>) {
            chomp $_;
            if ( $_ =~ /^\s*#/ )                                               { next; }
            if ( $_ =~ /^\s*(OFF|FATAL|ERROR|WARN|INFO|DEBUG|TRACE|ALL)\s*$/ ) { $config->{LOGLEVEL} = $1; }
        }
        close $FH;
    }
	#print Dumper $config;
    delete $config->{CONFIG};  
}

