sub changePW {
    my ( $request, $httpreq ) = @_;
    my %resp = %{ preInit( $request, $httpreq ) };

    $resp{Documentation}{get}{summary}     = 'A generic lookup of count into a given table based on a single key in one column';
    $resp{Documentation}{get}{description} = 'Optional extended description in CommonMark or HTML';
    $resp{Documentation}{get}{operationId} = NextId('Self Service');
    $resp{Documentation}{get}{tags}        = ['Self Service'];
    AddResponseDoc(\%resp,'GET','200 404 500');   
    
    my $line = $resp{Line};
    $line = getSingleValueParams( $line, \%param_uid,     \%resp, 'uid',    ['GET'], true );
    
    CommonApiHandler::getHeaderValueParams( \%CommonApiHandler::param_request_id, \%resp, 'X-Request-ID', ['GET'] );
    CommonApiHandler::getHeaderValueParams( \%CommonApiHandler::param_trace_id,   \%resp, 'X-TRACE-ID',   ['GET'] );
    CommonApiHandler::getHeaderValueParams( \%CommonApiHandler::param_accept,     \%resp, 'HTTP-ACCEPT',  ['GET'] );

    allParametersUsed( $line, \%resp );

    if ( !defined( $resp{api} ) ) {
		if ( $ENV{'REQUEST_METHOD'} eq 'GET' ) {
            ### Create new UUID / used for encryption
            $resp{HeaderParams}{'X-TRACE-ID'} = uuid::get_trace_id(); 
            my %Object = ();
        	$Object{function}   = 'chpw';
            $Object{sessionid}  = $resp{HeaderParams}{'X-TRACE-ID'};
        	$Object{uid}        = $resp{Params}{uid};
            $resp{Params}{uuid} = $Object{sessionid};
            
            my $record = SessionFile::CreateRecord($Object{sessionid});
            $record    = SessionFile::UpdateRecord($record,'uid', $Object{uid});
			
			# Collect information from AD controller
			my $ad_record = ADConnection::userlookup_ad($resp{Params}{ uid });
			$resp{ad} = $ad_record;
			$record = SessionFile::UpdateRecord($record,'resetuser', $resp{Params}{ uid });
			$record = SessionFile::UpdateRecord($record,'mobile',    $ad_record->{ad_mobile});
			$record = SessionFile::UpdateRecord($record,'mail',      $ad_record->{ad_mail});

			# Collect information from OSS LDAP slave
			my %ldap = ();
			Authenticate::ldapLookupDeep(\%ldap, $resp{Params}{ uid });
			
			# Select password complexity level
			my $level  = getAccessLevel(\%ldap);
			$record = SessionFile::UpdateRecord($record,'level',    $level);	
			
            my $result = SessionFile::StoreRecord($record);
            logtosys('warning', "Failed to store record") if ($result == 0);
            
			#$resp{Params}{page} = uri_unescape($resp{Params}{page}); 
			$resp{strength} = $level;

			my $printPage   = undef;
			( $resp{status}, $resp{results}{txt}, $printPage ) = Pages::pages( 'two' );
			return(finelizeRequest(\%resp, $printPage,'text/html')) if (defined($printPage));

		}
    }
    return(finelizeRequest(\%resp)); 
}

sub getOTP {
    my ( $request, $httpreq ) = @_;
    my %resp = %{ preInit( $request, $httpreq ) };

    $resp{Documentation}{post}{summary}     = 'A generic lookup of count into a given table based on a single key in one column';
    $resp{Documentation}{post}{description} = 'Optional extended description in CommonMark or HTML';
    $resp{Documentation}{post}{operationId} = NextId('Self Service');
    $resp{Documentation}{post}{tags}        = ['Self Service'];
    AddResponseDoc(\%resp,'POST','200 404 500');   

    my $line = $resp{Line};
    $line = getSingleValueParams( $line, \%param_pages,   \%resp, 'page',   ['POST'], true );
    $line = getSingleValueParams( $line, \%param_uid,     \%resp, 'uid',    ['POST'], true );
    $line = getSingleValueParams( $line, \%param_psw,     \%resp, 'psw0',   ['POST'], true );
    $line = getSingleValueParams( $line, \%param_psw,     \%resp, 'psw1',   ['POST'], true );
    $line = getSingleValueParams( $line, \%param_uuid,    \%resp, 'uuid',   ['POST'], true );
    
    if ($ENV{'REQUEST_METHOD'} eq 'POST' ) {
        $resp{Params}{ page } = $httpreq->param('page');            # next page? three if OK
        $resp{Params}{ uid  } = $httpreq->param('usrname');
        $resp{Params}{ psw0 } = $httpreq->param('psw0');
        $resp{Params}{ psw1 } = $httpreq->param('psw1');
        $resp{Params}{ psw2 } = $httpreq->param('psw2');
        $resp{Params}{ uuid } = $httpreq->param('uuid');
        
        $resp{Params}{ psw0 }  = StringCrypt::myencrypt($resp{Params}{ uuid },$resp{Params}{ psw0 } );
        $resp{Params}{ psw1 }  = StringCrypt::myencrypt($resp{Params}{ uuid },$resp{Params}{ psw1 } );
    } 
    
    CommonApiHandler::getHeaderValueParams( \%CommonApiHandler::param_request_id, \%resp, 'X-Request-ID', ['POST'] );
    CommonApiHandler::getHeaderValueParams( \%CommonApiHandler::param_trace_id,   \%resp, 'X-TRACE-ID',   ['POST'] );
    CommonApiHandler::getHeaderValueParams( \%CommonApiHandler::param_accept,     \%resp, 'HTTP-ACCEPT',  ['POST'] );

    allParametersUsed( $line, \%resp );

	#$resp{HTTPREQUST}=$httpreq;
	#print Dumper $request;

	my $printPage = undef;

    if ( !defined( $resp{api} ) ) {
		if ($ENV{'REQUEST_METHOD'} eq 'POST' ) {
			### We need to know wich page got us here:
			my $nextPage = '';
			if    ($resp{Headers}{HTTP_REFERER} =~ /recoverLink/ ) { $nextPage = 'mailsent'; }
			elsif ($resp{Headers}{HTTP_REFERER} =~ /changePW/    ) { $nextPage = 'two';      }
			
			my ($result,$record) = SessionFile::GetRecord($resp{Params}{ uuid });
            if ($result == 0) {
                logtosys('err',     "GetRecord failed with uuid: " . $resp{Params}{ uuid });
                my $printPage = undef;
                ( $resp{status}, $resp{results}{txt}, $printPage ) = Pages::pages( 'head' );
                return(finelizeRequest(\%resp, $printPage,'text/html')) if (defined($printPage));
            }            
			
            # Update record
			$record = SessionFile::UpdateRecord($record,'nextPage',  $nextPage);
			$record = SessionFile::UpdateRecord($record,'oldpasswd', $resp{Params}{ psw0 });
			$record = SessionFile::UpdateRecord($record,'newpasswd', $resp{Params}{ psw1 });
			
			
			# Collect information from AD controller
			my $ad_record = ADConnection::userlookup_ad($resp{Params}{ uid });
			$resp{ad} = $ad_record;
			$record = SessionFile::UpdateRecord($record,'mobile',  $ad_record->{ad_mobile});
			$record = SessionFile::UpdateRecord($record,'mail',    $ad_record->{ad_mail});
			my %ldap = ();
			Authenticate::ldapLookupDeep(\%ldap, $resp{Params}{ uid });
			$resp{ldap} = \%ldap;
			$resp{session_record} = $record;
        
			# strengthcheck
			$resp{level} = getAccessLevel(\%ldap);
			$record = SessionFile::UpdateRecord($record,'level',  $resp{level});
			
			($resp{check}{strength},$resp{check}{score},$resp{check}{crack_times},$resp{check}{libraries}) = 
												strengthcheck::testPW (\%resp, StringCrypt::mydecrypt($resp{Params}{ uuid },$resp{Params}{ psw1 } ));
			
			# print STDERR Dumper \$resp{check};
			my $libstr = undef;
			for my $libs (keys %{$resp{check}{libraries}}) {
				next if (!($libs =~ /passwords/));
				if (defined($libstr)) {$libstr .= '<br>';}
				$libstr .= $resp{check}{libraries}{$libs}{token} . ": found in library " . $resp{check}{libraries}{$libs}{library};
			}
			$resp{check}{libraryList} = $libstr;
			
	        if ($resp{check}{strength} eq 'Failed' ) {
					# Store updated
					$record = SessionFile::UpdateRecord($record,'nextPage',  $nextPage);
					$resp{result} = SessionFile::StoreRecord($record);
                    logtosys('warning', "Failed to store record") if ($resp{result} == 0);
					( $resp{status}, $resp{results}{txt}, $printPage ) = Pages::pages( 'weak' );
					return(finelizeRequest(\%resp, $printPage,'text/html')) if (defined($printPage));				
		    } elsif ($resp{check}{strength} eq 'Accepted' ) {
				# check new password with
                my $resultAD = ADConnection::Authenticate($resp{Params}{ uid  },StringCrypt::mydecrypt($resp{Params}{ uuid },$resp{Params}{ psw1 } ));
                if ($resultAD == 1 and (($resp{level} eq 'GROUPADMINPW') or ($resp{level} eq 'GROUPSUPERPW'))) {
                    # Store updated
                    $record = SessionFile::UpdateRecord($record, 'nextPage', $nextPage);
                    $resp{result} = SessionFile::StoreRecord($record);
                    logtosys('warning', "Failed to store record") if ($resp{result} == 0);
                    ( $resp{status}, $resp{results}{txt}, $printPage ) = Pages::pages( 'failedad' );   
                    return(finelizeRequest(\%resp, $printPage,'text/html')) if (defined($printPage));
                }
                # Create OTP code 
                my $otp = Generator::getNewOTP();
                $record = SessionFile::UpdateRecord($record,'nextPage', $nextPage);
                $otp    = StringCrypt::myencrypt($resp{Params}{ uuid }, $otp );
                $record = SessionFile::UpdateRecord($record,'otp_token', $otp);
                # Store updated
                $resp{result} = SessionFile::StoreRecord($record);
                logtosys('warning', "Failed to store record") if ($resp{result} == 0);
                # Send OTP
                $resp{otp_response} = TokenAPI::OTPSendSMS($record->{mobile},  
                                      StringCrypt::mydecrypt($resp{Params}{ uuid },$otp )) if (defined($record->{mobile}));
                $resp{Params}{page} = uri_unescape($resp{Params}{page}); 
                ( $resp{status}, $resp{results}{txt}, $printPage ) = Pages::pages( $resp{Params}{ page } );
                return(finelizeRequest(\%resp, $printPage,'text/html')) if (defined($printPage));
                
			} 
		}
    }
	( $resp{status}, $resp{results}{txt}, $printPage ) = Pages::pages( 'weakxxx' );
	return(finelizeRequest(\%resp, $printPage,'text/html')) if (defined($printPage));
    #return(finelizeRequest(\%resp)); 
}

